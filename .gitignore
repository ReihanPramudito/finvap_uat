error.txt

# real client Nessus scans (sensitive infra data) — never commit; keep test fixtures
*.nessus
!tests/fixtures/*.nessus

# Claude Code local (machine-specific) settings
.claude/settings.local.json

# VibeDocs — separate third-party web app (its own git repo), UI reference only
VibeDocs/
