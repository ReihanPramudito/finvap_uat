.venv/
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.pytest_cache/

# runtime data / secrets
data/
*.db
.env
.chroma/

# operator preferences for the orchestrator (machine-specific)
finvap.config.json

# engagement metadata for custom report templates (carries client identifiers)
